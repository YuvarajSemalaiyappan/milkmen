{
  "name": "milkmen",
  "version": "1.0.0",
  "description": "Milk Collection & Sales Management PWA",
  "private": true,
  "workspaces": [
    "apps/*",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/mobile-web",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "start": "node start-dev.js",
    "build": "npm run build --workspace=apps/mobile-web",
    "build:server": "npm run build --workspace=server",
    "build:render": "npm run db:generate && npm run build && npm run build --workspace=apps/admin-panel && npm run build:server",
    "start:server": "npm run start --workspace=server",
    "db:generate": "npm run db:generate --workspace=server",
    "db:push": "npm run db:push --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:studio": "npm run db:studio --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "engines": {
    "node": "22.x"
  }
}
