# Database
# Local:
DATABASE_URL="postgresql://username:password@localhost:5432/milkmen?schema=public"
# Neon (production):
# DATABASE_URL="postgresql://user:pass@ep-xxx-yyy.region.aws.neon.tech/milkmen?sslmode=require"

# Server
PORT=4000
NODE_ENV=development

# CORS (not needed in production — frontend served from same origin)
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin Setup (use once, then remove)
SETUP_SECRET=your-setup-secret-for-admin-init
